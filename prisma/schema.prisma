generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  password            String   
  name                String   
  createdAt           DateTime @default(now())

  setLogs             SetLog[]
  ratingHistories     RatingHistory[]
}

model SetLog {
  id                  Int      @id @default(autoincrement())
  userId              String
  exercise            String
  weight              Float
  reps                Int
  estimatedOneRepMax  Float
  createdAt           DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RatingHistory {
  id        Int      @id @default(autoincrement())
  userId    String
  exercise  String
  rating    Float
  delta     Float
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
