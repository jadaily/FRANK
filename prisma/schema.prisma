generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SetLog {
  id                  Int      @id @default(autoincrement())
  userId              String
  exercise            String
  weight              Float
  reps                Int
  estimatedOneRepMax  Float
  createdAt           DateTime @default(now())
}

model RatingHistory {
  id        Int      @id @default(autoincrement())
  userId    String
  exercise  String
  rating    Float
  delta     Float
  createdAt DateTime @default(now())
}
